---
import Layout from "../layouts/Layout.astro";
import AIGeneratorContainer from "../components/ai-generator/AIGeneratorContainer";

const title = "Generator AI - 10x Cards";
---

<Layout title={title}>
  <main class="container mx-auto p-4 md:p-6">
    <h1 class="text-3xl font-bold mb-6">Generator AI</h1>
    <div class="mb-4">
      <p class="text-gray-700 dark:text-gray-300">
        Automatycznie generuj fiszki z wprowadzonego tekstu przy pomocy sztucznej inteligencji.
      </p>
    </div>
    <AIGeneratorContainer client:load />
  </main>
</Layout>
