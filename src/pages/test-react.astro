---
import Layout from '../layouts/Layout.astro';
import TestReactComponent from '../components/TestReactComponent';
---

<Layout title="Test React" description="Strona testowa dla komponentów React">
  <div class="container mx-auto py-8">
    <h1 class="text-3xl font-bold mb-8">Test Hydratacji React</h1>
    
    <!-- Testowy komponent React z dyrektywą client:load -->
    <div class="mb-8">
      <h2 class="text-2xl font-bold mb-4">Komponent z client:load</h2>
      <TestReactComponent client:load />
    </div>
    
    <!-- Prosty test JavaScript bez React -->
    <div class="mb-8 p-4 border rounded-md">
      <h2 class="text-2xl font-bold mb-4">Test JavaScript</h2>
      <button id="test-js-button" class="bg-blue-500 hover:bg-blue-700 text-white font-bold py-2 px-4 rounded">
        Kliknij mnie (Vanilla JS)
      </button>
      <p id="test-js-result" class="mt-4"></p>
    </div>
  </div>
</Layout>

<script>
  // Prosty skrypt do testowania Vanilla JavaScript
  document.addEventListener('DOMContentLoaded', () => {
    console.log('Strona załadowana - vanilla JavaScript działa');
    
    const button = document.getElementById('test-js-button');
    const result = document.getElementById('test-js-result');
    
    if (button && result) {
      button.addEventListener('click', () => {
        console.log('Przycisk Vanilla JS kliknięty');
        result.textContent = 'Przycisk został kliknięty! JavaScript działa! ' + new Date().toLocaleTimeString();
      });
    }
  });
</script>
